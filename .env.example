APP_NAME=E-Commerce Retail Intelligence Platform
ENVIRONMENT=development

# Local SQLite database
DATABASE_URL=sqlite:///retail_intelligence.db

# API runtime mode
# local = SQLite mode
# azure = Azure SQL Database mode
APP_ENV=local

# JWT Authentication
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Demo JWT Users
JWT_ADMIN_USERNAME=admin
JWT_ADMIN_PASSWORD=your-admin-password
JWT_ANALYST_USERNAME=analyst
JWT_ANALYST_PASSWORD=your-analyst-password
JWT_VIEWER_USERNAME=viewer
JWT_VIEWER_PASSWORD=your-viewer-password

# Azure Blob Storage
AZURE_STORAGE_CONNECTION_STRING=replace_with_azure_storage_connection_string
AZURE_BLOB_CONTAINER_NAME=ecommerce-retail-data
AZURE_BLOB_RAW_PREFIX=raw/olist

# Azure SQL Database
# In local development, these can be stored in .env.
# In Azure App Service, sensitive values are stored in Azure Key Vault
# and referenced through App Service Key Vault references.
AZURE_SQL_CONNECTION_STRING=replace_with_azure_sql_connection_string
AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=sqldb-ecommerce-retail-intelligence
AZURE_SQL_USERNAME=your_sql_admin_username
AZURE_SQL_PASSWORD=your_sql_admin_password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# FastAPI Authentication
# Demo placeholders only.
# In Azure App Service, real API keys are stored in Azure Key Vault.
ADMIN_API_KEY=admin-demo-key
ANALYST_API_KEY=analyst-demo-key
VIEWER_API_KEY=viewer-demo-key

# Azure App Service
AZURE_APP_BASE_URL=https://your-app-name.azurewebsites.net
WEBSITES_PORT=8000

# Azure Key Vault
AZURE_KEY_VAULT_NAME=your-key-vault-name

# Azure Monitoring
AZURE_APPLICATION_INSIGHTS_NAME=appi-ecommerce-retail-api
AZURE_MONITOR_AVAILABILITY_TEST_NAME=fastapi-health-check