APP_NAME=E-Commerce Retail Intelligence Platform
ENVIRONMENT=development

DATABASE_URL=sqlite:///retail_intelligence.db

JWT_SECRET_KEY=replace_with_your_secret_key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

OPENAI_API_KEY=replace_with_your_openai_key

# Azure Services
AZURE_STORAGE_CONNECTION_STRING=replace_with_azure_storage_connection_string
AZURE_BLOB_CONTAINER_NAME=ecommerce-retail-data
AZURE_BLOB_RAW_PREFIX=raw/olist
AZURE_SQL_CONNECTION_STRING=replace_with_azure_sql_connection_string

AZURE_SQL_SERVER=your-server-name.database.windows.net
AZURE_SQL_DATABASE=sqldb-ecommerce-retail-intelligence
AZURE_SQL_USERNAME=your_sql_admin_username
AZURE_SQL_PASSWORD=your_sql_admin_password
AZURE_SQL_DRIVER=ODBC Driver 18 for SQL Server

# FastAPI Authentication
ADMIN_API_KEY=admin-demo-key
ANALYST_API_KEY=analyst-demo-key
VIEWER_API_KEY=viewer-demo-key