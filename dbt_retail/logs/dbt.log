SELECT
    dc.customer_state,
    COUNT(DISTINCT fd.order_id) AS total_orders,
    SUM(fd.is_late_delivery) AS late_orders,
    ROUND(
        100.0 * SUM(fd.is_late_delivery) / COUNT(DISTINCT fd.order_id),
