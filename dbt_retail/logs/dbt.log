    create view main."vw_customer_state_performance" as
    

SELECT
    dc.customer_state,
    COUNT(DISTINCT fs.order_id) AS total_orders,
    COUNT(*) AS total_order_items,
    ROUND(SUM(fs.item_price), 2) AS product_revenue,
