SELECT
    fd.order_status,
    COUNT(DISTINCT fd.order_id) AS total_orders,
    SUM(fd.is_delivered) AS delivered_orders,
    SUM(fd.is_late_delivery) AS late_deliveries,
    SUM(fd.has_missing_delivery_date) AS missing_delivery_date_orders,
